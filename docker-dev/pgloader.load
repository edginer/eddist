-- pgloader configuration for MySQL → PostgreSQL migration
-- Phase: Co-existence (continuous replication via binlog)
--
-- Prerequisites:
--   1. MySQL binlog enabled: binlog_format=ROW, server-id set
--   2. PostgreSQL schema pre-created via:
--        DATABASE_URL=postgres://postgres:pgpassword@localhost:5432/eddist \
--          sqlx migrate run --source migrations/pg
--   3. pgcrypto extension installed (added by migration 20241230174144)
--
-- Run modes:
--   One-time load:   docker compose --profile migrate up pgloader
--   Continuous sync: Add REPLICATION MODE CDC to the LOAD DATABASE block (requires pgloader pro)
--                    For OSS pgloader, run repeatedly or use an external CDC tool.

LOAD DATABASE
    FROM mysql://root:rootpassword@mysql:3306/eddist
    INTO postgresql://postgres:pgpassword@postgres:5432/eddist

WITH
    -- Do not recreate tables (schema already applied via sqlx migrate)
    include drop,
    create tables,
    no truncate,
    create indexes,
    reset sequences,
    foreign keys,

    -- Workers
    workers = 4,
    concurrency = 1

CAST
    -- UUID: BINARY(16) → uuid
    -- pgloader's built-in byte-vector-to-uuid-string handles MySQL's UUID_TO_BIN storage
    column authed_tokens.id           to uuid drop typemod using byte-vector-to-uuid-string,
    column boards.id                  to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_info.id             to uuid drop typemod using byte-vector-to-uuid-string,
    column threads.id                 to uuid drop typemod using byte-vector-to-uuid-string,
    column threads.board_id           to uuid drop typemod using byte-vector-to-uuid-string,
    column threads.authed_token_id    to uuid drop typemod using byte-vector-to-uuid-string,
    column responses.id               to uuid drop typemod using byte-vector-to-uuid-string,
    column responses.authed_token_id  to uuid drop typemod using byte-vector-to-uuid-string,
    column responses.board_id         to uuid drop typemod using byte-vector-to-uuid-string,
    column responses.thread_id        to uuid drop typemod using byte-vector-to-uuid-string,
    column caps.id                    to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_caps.id             to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_caps.board_id       to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_caps.cap_id         to uuid drop typemod using byte-vector-to-uuid-string,
    column ng_words.id                to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_ng_words.id         to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_ng_words.board_id   to uuid drop typemod using byte-vector-to-uuid-string,
    column boards_ng_words.ng_word_id to uuid drop typemod using byte-vector-to-uuid-string,
    column admin_roles.id             to uuid drop typemod using byte-vector-to-uuid-string,
    column admin_role_scopes.id       to uuid drop typemod using byte-vector-to-uuid-string,
    column admin_role_scopes.role_id  to uuid drop typemod using byte-vector-to-uuid-string,
    column admin_users.id             to uuid drop typemod using byte-vector-to-uuid-string,
    column admin_users.user_role_id   to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_threads.id        to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_threads.board_id  to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_threads.authed_token_id to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_responses.id              to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_responses.authed_token_id to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_responses.board_id        to uuid drop typemod using byte-vector-to-uuid-string,
    column archived_responses.thread_id       to uuid drop typemod using byte-vector-to-uuid-string,
    column idps.id                    to uuid drop typemod using byte-vector-to-uuid-string,
    column users.id                   to uuid drop typemod using byte-vector-to-uuid-string,
    column user_idp_bindings.id       to uuid drop typemod using byte-vector-to-uuid-string,
    column user_idp_bindings.user_id  to uuid drop typemod using byte-vector-to-uuid-string,
    column user_idp_bindings.idp_id   to uuid drop typemod using byte-vector-to-uuid-string,
    column user_authed_tokens.id              to uuid drop typemod using byte-vector-to-uuid-string,
    column user_authed_tokens.user_id         to uuid drop typemod using byte-vector-to-uuid-string,
    column user_authed_tokens.authed_token_id to uuid drop typemod using byte-vector-to-uuid-string,
    column authed_tokens.registered_user_id   to uuid drop typemod using byte-vector-to-uuid-string,
    column user_restriction_rules.id  to uuid drop typemod using byte-vector-to-uuid-string,
    column notices.id                 to uuid drop typemod using byte-vector-to-uuid-string,
    column terms.id                   to uuid drop typemod using byte-vector-to-uuid-string,
    column captcha_configs.id         to uuid drop typemod using byte-vector-to-uuid-string,
    column server_settings.id         to uuid drop typemod using byte-vector-to-uuid-string,

    -- BINARY(64): author_id_seed → bytea
    column authed_tokens.author_id_seed to bytea drop typemod,

    -- DATETIME → timestamptz (pgloader handles automatically with type matching)
    type datetime to timestamptz drop typemod,

    -- TINYINT(1) / BIT used as boolean → boolean
    type tinyint to boolean drop typemod using tinyint-to-boolean,

    -- ENUM → text (PostgreSQL uses a named enum type defined in the schema)
    column user_restriction_rules.rule_type to "restriction_rule_type" drop typemod,

    -- JSON → jsonb
    type json to jsonb drop typemod

SET maintenance_work_mem to '256 MB',
    work_mem to '64 MB'

AFTER LOAD DO
$$
    -- Verify row counts match after initial load
    -- Run: SELECT schemaname, tablename, n_live_tup FROM pg_stat_user_tables ORDER BY tablename;
    SELECT 'pgloader migration complete' AS status;
$$;
