  "query": "SELECT\n                board_key,\n                date AS \"date: NaiveDate\",\n                total_responses,\n                new_threads\n            FROM daily_stats\n            WHERE date >= DATE_SUB(DATE(CONVERT_TZ(NOW(), '+00:00', '+09:00')), INTERVAL ? DAY)\n              AND date < DATE(CONVERT_TZ(NOW(), '+00:00', '+09:00'))\n            ORDER BY date DESC, board_key",
